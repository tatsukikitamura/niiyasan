---
import Base from '../layouts/Base.astro';
import Shell from '../components/ui/Shell.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import SecHead from '../components/ui/SecHead.astro';
import PageWrap from '../components/ui/PageWrap.astro';
import { aboutImages, resolveImg } from '../utils/siteImages';
import { photoFor } from '../utils/placeholders';

const facts: [string, string][] = [
  ['チーム名', 'Moovit'],
  ['設立', '2026年5月'],
  ['所在地', '東京都港区麻布十番 1-2-3 麻布スタジオ 4F'],
  ['代表', '新家 真二'],
  ['事業内容', '映像制作 / 楽曲制作 / イベント制作 / アーティストの活動支援'],
  ['取引銀行', '三井住友銀行'],
];

const philosophy = [
  {
    n: '01',
    t: '聴くことから、はじめる。',
    d: 'どんな企画も、まずは話を聴くことから。提案は、その後です。あなたの言葉に、まずは静かに耳をかたむけます。',
  },
  {
    n: '02',
    t: '手の届く距離で、つくる。',
    d: 'プロジェクトは、ひとり〜数人の小さなチームで担当します。あなたの想いが、最後まで薄まらずに届くように。',
  },
  {
    n: '03',
    t: '納品の、その先まで。',
    d: '作品は世に出てから、ようやく動きはじめます。届け方、伸ばし方の相談まで、ずっとそばで考えます。',
  },
];

const studioBg = `url('${resolveImg(aboutImages.studio, photoFor('studio', 0, { w: 2000, h: 900 }))}')`;
---

<Base
  title="About — Moovit | 麻布十番のクリエイティブスタジオ"
  description="Moovit は、つくる人のそばに在りたいと願う、映像・楽曲・イベント制作のクリエイティブスタジオです。聴くことからはじめ、手の届く距離でつくり、納品の先まで伴走します。"
>
  <PageWrap>
    <Shell>
      <section
        class="grid grid-cols-1 items-end gap-16 pb-20 pt-[120px] lg:grid-cols-2 lg:pt-[140px]"
      >
        <div>
          <Eyebrow>About — 会社について</Eyebrow>
          <div class="h-8"></div>
          <h1 class="font-serif text-hero font-normal text-ink-900">
            つくる人の、
            <br />
            <em class="not-italic text-accent">そばに。</em>
          </h1>
        </div>
        <div class="flex flex-col gap-6">
          <p class="text-[15px] leading-[1.8] text-ink-600">
             "つくりたい" その思いに最後まで伴走したい — その信念を抱えて、私達は存在します。
          </p>
          <p class="text-[15px] leading-[1.8] text-ink-600">
            映像、音楽、イベント。手がける領域は広がりましたが、芯は変わりません。
            "あなたの声を、聴く"こと。 それがわたしたちの最初の仕事です。
          </p>
        </div>
      </section>
    </Shell>

    <Shell>
      <div
        class="my-16 aspect-[21/9] w-full overflow-hidden bg-ink-300 bg-cover bg-center"
        style={`background-image:${studioBg}`}
        role="img"
        aria-label="Moovit のスタジオ風景"
      >
      </div>
    </Shell>

    <Shell>
      <section class="py-section-tight">
        <SecHead eyebrow="Philosophy">
          <Fragment slot="title">わたしたちの、<br />三つの約束。</Fragment>
          <p slot="right" class="text-[15px] leading-[1.8] text-ink-600">
            言葉にすると、当たり前のことかもしれません。でも、当たり前のことを当たり前にやりつづけること — それがいちばん難しい。
          </p>
        </SecHead>
        <div class="grid grid-cols-1 gap-12 py-16 lg:grid-cols-3">
          {
            philosophy.map((p) => (
              <div class="flex flex-col gap-4">
                <div class="font-mono text-[11px] tracking-[0.2em] text-accent">— {p.n}</div>
                <h2 class="font-serif text-[28px] font-normal leading-[1.2] tracking-[-0.01em] text-ink-900">
                  {p.t}
                </h2>
                <p class="text-[14px] leading-[1.75] text-ink-600">{p.d}</p>
              </div>
            ))
          }
        </div>
      </section>
    </Shell>

    <Shell>
      <dl
        class="grid grid-cols-1 gap-2 border-t border-ink-200 py-16 lg:grid-cols-[200px_1fr] lg:gap-x-12 lg:gap-y-6"
      >
        {
          facts.map(([k, v]) => (
            <div class="contents">
              <dt class="pt-1 font-mono text-[11px] uppercase tracking-[0.16em] text-ink-500">
                {k}
              </dt>
              <dd class="m-0 border-b border-ink-200 pb-4 text-[15px] text-ink-800 lg:pb-6">{v}</dd>
            </div>
          ))
        }
      </dl>
    </Shell>
  </PageWrap>
</Base>
