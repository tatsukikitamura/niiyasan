---
import Base from '../layouts/Base.astro';
import Shell from '../components/ui/Shell.astro';
import Eyebrow from '../components/ui/Eyebrow.astro';
import Label from '../components/ui/Label.astro';
import SecHead from '../components/ui/SecHead.astro';
import Btn from '../components/ui/Btn.astro';
import PageWrap from '../components/ui/PageWrap.astro';
import Reveal from '../components/Reveal.astro';
import Icon from '../components/icons.astro';
import { works } from '../data/works';
import { worksImages, resolveImg } from '../utils/siteImages';
import { photoFor } from '../utils/placeholders';
import { withBase } from '../utils/url';

const featSpans = [7, 5, 4, 8] as const;
type Span = (typeof featSpans)[number];

const featured = works.slice(0, 4).map((w, i) => ({
  t: w.t,
  cat: w.sub,
  span: featSpans[i],
  seed: w.seed,
  kind: w.kind,
  img: worksImages[i] ?? '',
  href: withBase('/works/'),
}));

const spanCls: Record<Span, string> = {
  7: 'lg:col-span-7 aspect-[16/10]',
  5: 'lg:col-span-5 aspect-[16/10] lg:aspect-[4/4.6]',
  4: 'lg:col-span-4 aspect-[16/10] lg:aspect-[4/3]',
  8: 'lg:col-span-8 aspect-[16/10] lg:aspect-[16/9]',
};

const services = [
  {
    n: '01',
    en: 'Visual',
    jp: '動画制作',
    desc: 'ミュージックビデオ、ドキュメンタリー、ライブ収録。映像のすべてを、構想から納品まで一貫してサポートします。',
    tags: ['MV', 'Documentary', 'Live', 'CM'],
    href: withBase('/services/') + '#visual',
  },
  {
    n: '02',
    en: 'Music',
    jp: '楽曲制作',
    desc: '作曲・編曲・録音・ミックス。アーティストの声に寄り添い、世界観を音で立ち上げます。',
    tags: ['Compose', 'Arrange', 'Mix', 'Master'],
    href: withBase('/services/') + '#sonic',
  },
  {
    n: '03',
    en: 'Stage',
    jp: 'イベント制作',
    desc: '一瞬の熱狂を、一生の記憶に。ライブ、リリースパーティー、ポップアップ。私たちがデザインするのは、単なる場所ではなく、そこで生まれる「忘れられない体験」そのものです。',
    tags: ['Live', 'Party', 'Popup', 'Tour'],
    href: withBase('/services/') + '#stage',
  },
];

const journal = [
  { d: '2026.05.02', c: 'News', t: 'HPを開設しました。', href: withBase('/blog/') },
  {
    d: '2026.03.30',
    c: 'Interview',
    t: 'アーティスト悠針れいと話した、夜の音について。',
    href: withBase('/blog/'),
  },
  {
    d: '2026.03.10',
    c: 'Notes',
    t: 'ミックスダウンで意識している、たった三つのこと。',
    href: withBase('/blog/'),
  },
];

// schema.org/url は絶対 URL。site + base を結合。
const SITE = 'https://tatsuki.dev/niiyasan/';

const orgJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Moovit',
  url: SITE,
  logo: `${SITE}favicon.svg`,
  description:
    '麻布十番のクリエイティブスタジオ Moovit。動画制作・楽曲制作・イベント制作を一気通貫で支えます。',
  foundingDate: '2026-05',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '麻布十番 1-2-3 麻布スタジオ 4F',
    addressLocality: '港区',
    addressRegion: '東京都',
    addressCountry: 'JP',
  },
  areaServed: 'Tokyo',
};

const localBusinessJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: 'Moovit',
  url: SITE,
  description:
    '映像・楽曲・イベント制作のクリエイティブスタジオ。アーティストの活動を一気通貫で支えます。',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '麻布十番 1-2-3 麻布スタジオ 4F',
    addressLocality: '港区',
    addressRegion: '東京都',
    addressCountry: 'JP',
  },
  areaServed: 'Tokyo',
  foundingDate: '2026-05',
};
---

<Base
  title="Moovit — つくる人のそばに。"
  description="麻布十番のクリエイティブスタジオ Moovit。動画制作・楽曲制作・イベント制作を一気通貫で支えます。アーティスト・クリエイターの表現に寄り添うチームです。"
  jsonLd={[orgJsonLd, localBusinessJsonLd]}
>
  <PageWrap>
    <Shell class="relative pb-16 pt-28">
      <div class="mb-6 flex flex-wrap items-end justify-between gap-8">
        <Eyebrow>Tokyo · Est. 2026</Eyebrow>
        <Label>Issue 026 — Spring 2026</Label>
      </div>

      <h1 class="font-serif text-hero font-normal text-ink-900">
        <span class="block overflow-hidden pt-[0.12em]">
          <span class="inline-block animate-rise">音と映像で、</span>
        </span>
        <span class="block overflow-hidden pt-[0.12em]">
          <span class="inline-block animate-rise [animation-delay:0.15s]">
            <em class="not-italic text-accent">記憶</em>を。
          </span>
        </span>
      </h1>

      <div
        class="mt-12 grid grid-cols-1 items-end gap-8 border-t border-ink-200 pt-10 md:grid-cols-2"
      >
        <p class="max-w-[480px] font-serif text-lede text-ink-700">
          アーティスト、クリエイター、表現者のみなさんへ。
          <br />
          映像・楽曲・イベント — つくりたいものは違っても、
          <br />
          届けたい景色は、いつもひとつです。
        </p>
        <div class="flex flex-wrap gap-3 md:justify-self-end">
          <Btn variant="primary" href={withBase('/contact/')}>Start a project</Btn>
          <Btn variant="ghost" href={withBase('/works/')}>See works</Btn>
        </div>
      </div>
    </Shell>

    <div class="overflow-hidden border-y border-ink-200 bg-ink-50 py-6">
      <div class="flex animate-marquee gap-16 whitespace-nowrap font-serif text-marquee text-ink-800">
        {
          [0, 1].map(() => (
            <div class="flex shrink-0 items-center gap-16">
              <span class="font-serif">
                <em class="not-italic">Music Video</em>
              </span>
              <span class="mx-8 inline-block h-2 w-2 shrink-0 self-center rounded-full bg-accent" />
              <span class="font-serif">Live Production</span>
              <span class="mx-8 inline-block h-2 w-2 shrink-0 self-center rounded-full bg-accent" />
              <span class="font-serif">
                <em class="not-italic">Composition</em>
              </span>
              <span class="mx-8 inline-block h-2 w-2 shrink-0 self-center rounded-full bg-accent" />
              <span class="font-serif">楽曲制作</span>
              <span class="mx-8 inline-block h-2 w-2 shrink-0 self-center rounded-full bg-accent" />
              <span class="font-serif">
                <em class="not-italic">Stage</em>
              </span>
              <span class="mx-8 inline-block h-2 w-2 shrink-0 self-center rounded-full bg-accent" />
              <span class="font-serif">映像制作</span>
              <span class="mx-8 inline-block h-2 w-2 shrink-0 self-center rounded-full bg-accent" />
            </div>
          ))
        }
      </div>
    </div>

    <Shell>
      <section class="py-section">
        <SecHead eyebrow="Selected Works · 2025—26">
          <Fragment slot="title">最近のしごと。</Fragment>
          <p slot="right" class="text-[15px] leading-[1.8] text-ink-600">
            アーティストの想いに耳を澄ませ、ひとつひとつ丁寧につくってきました。すべての仕事に、わたしたちなりの "誠実さ" を込めて。
          </p>
        </SecHead>
        <Reveal>
          <div class="mt-16 grid grid-cols-1 gap-6 lg:grid-cols-12">
            {
              featured.map((f) => (
                <a
                  href={f.href}
                  class={`group relative cursor-pointer overflow-hidden bg-ink-200 ${spanCls[f.span]}`}
                  aria-label={`${f.t} の詳細を見る`}
                >
                  <div
                    class="absolute inset-0 bg-cover bg-center transition-transform duration-800 ease-smooth group-hover:scale-[1.04]"
                    style={`background-image:url('${resolveImg(f.img, photoFor(f.kind, f.seed, { w: 1200, h: 800 }))}')`}
                  />
                  <div class="absolute inset-0 bg-gradient-to-b from-transparent from-40% to-[rgba(14,13,12,0.7)]" />
                  <div class="absolute inset-x-6 bottom-[22px] flex items-end justify-between gap-4 text-ink-50">
                    <div class="font-serif text-feat-title">{f.t}</div>
                    <div class="font-mono text-[10px] uppercase tracking-[0.18em] opacity-85">
                      {f.cat}
                    </div>
                  </div>
                </a>
              ))
            }
          </div>
        </Reveal>
      </section>
    </Shell>

    <Shell>
      <section class="py-section-tight">
        <SecHead eyebrow="What we do">
          <Fragment slot="title">三つの場所で、<br />表現を支える。</Fragment>
          <p slot="right" class="text-[15px] leading-[1.8] text-ink-600">
            映像、音楽、イベント。それぞれ独立した領域でありながら、わたしたちの中ではすべてが地続きです。"つくる" を一気通貫で支えられること、それがわたしたちの強み。
          </p>
        </SecHead>
      </section>
    </Shell>

    <Shell>
      <div class="grid grid-cols-1 border-t border-ink-200 lg:grid-cols-3">
        {
          services.map((s) => (
            <a
              href={s.href}
              class="group relative flex min-h-[380px] flex-col gap-6 border-b border-ink-200 p-8 transition-colors duration-[400ms] hover:bg-ink-0 lg:border-r lg:[&:nth-child(3n)]:border-r-0 lg:p-12"
            >
              <div class="font-mono text-[11px] tracking-[0.2em] text-ink-400 transition-colors duration-300 group-hover:text-accent">
                — {s.n} / 03
              </div>
              <div class="absolute right-8 top-12 flex h-7 w-7 items-center justify-center rounded-full border border-ink-300 transition-all duration-300 group-hover:-rotate-45 group-hover:border-ink-900 group-hover:bg-ink-900 group-hover:text-ink-50">
                <Icon name="arrow-diag" size={12} />
              </div>
              <div class="font-serif text-svc-title text-ink-900">
                <em class="not-italic">{s.en}</em>
                <span class="mt-2 block font-sans text-[14px] font-medium tracking-[0.04em] text-ink-600">
                  {s.jp}
                </span>
              </div>
              <div class="text-[14px] leading-[1.75] text-ink-600">{s.desc}</div>
              <div class="mt-auto flex flex-wrap gap-1.5">
                {s.tags.map((t) => (
                  <span class="rounded-full border border-ink-300 px-2.5 py-1 font-mono text-[10px] uppercase tracking-[0.12em] text-ink-500">
                    {t}
                  </span>
                ))}
              </div>
            </a>
          ))
        }
      </div>
    </Shell>

    <Shell>
      <section class="py-section">
        <div class="grid grid-cols-2 gap-8 border-y border-ink-200 py-12 lg:grid-cols-4">
          <div class="flex flex-col gap-2">
            <div class="font-serif text-numbers-v leading-none text-ink-900">
              142<span class="ml-1 inline-block translate-y-[-0.6em] font-mono text-[0.22em] uppercase tracking-[0.08em] text-accent">+</span>
            </div>
            <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink-500">
              Projects delivered
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <div class="font-serif text-numbers-v leading-none text-ink-900">38</div>
            <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink-500">
              Artists collaborated
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <div class="font-serif text-numbers-v leading-none text-ink-900">
              7<span class="ml-1 inline-block translate-y-[-0.6em] font-mono text-[0.22em] uppercase tracking-[0.08em] text-accent">yr</span>
            </div>
            <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink-500">
              Years in motion
            </div>
          </div>
          <div class="flex flex-col gap-2">
            <div class="font-serif text-numbers-v leading-none text-ink-900">∞</div>
            <div class="font-mono text-[11px] uppercase tracking-[0.16em] text-ink-500">
              Stories ahead
            </div>
          </div>
        </div>
      </section>
    </Shell>

    <Shell>
      <section class="py-section">
        <SecHead eyebrow="Journal">
          <Fragment slot="title">最新の記録。</Fragment>
          <div slot="right" class="flex items-end justify-end">
            <Btn variant="ghost" href={withBase('/blog/')}>All entries</Btn>
          </div>
        </SecHead>
        <div class="pt-12">
          {
            journal.map((p) => (
              <a
                href={p.href}
                class="group grid grid-cols-1 items-center gap-8 border-b border-ink-200 py-6 transition-[padding] duration-300 hover:pl-3 lg:grid-cols-[110px_200px_1fr_100px]"
              >
                <div class="font-mono text-[12px] tracking-[0.04em] text-ink-500">{p.d}</div>
                <div class="w-fit rounded-full border border-ink-300 px-3 py-1 font-mono text-[10px] uppercase tracking-[0.16em] text-ink-700">
                  {p.c}
                </div>
                <div class="font-serif text-[19px] leading-[1.35] tracking-[-0.005em] text-ink-900">
                  {p.t}
                </div>
                <div class="font-mono text-[14px] text-ink-500 transition-[transform,color] duration-300 group-hover:translate-x-1 group-hover:-translate-y-1 group-hover:text-accent lg:justify-self-end">
                  ↗
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </Shell>
  </PageWrap>
</Base>
