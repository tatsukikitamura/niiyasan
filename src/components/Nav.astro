---
import Icon from './icons.astro';
import { withBase } from '../utils/url';

const links = [
  { href: withBase('/'), label: 'Home', match: withBase('/') },
  { href: withBase('/about/'), label: 'About', match: withBase('/about/') },
  { href: withBase('/services/'), label: 'Services', match: withBase('/services/') },
  { href: withBase('/works/'), label: 'Works', match: withBase('/works/') },
  { href: withBase('/blog/'), label: 'Journal', match: withBase('/blog/') },
] as const;

const homePath = withBase('/');
const path = Astro.url.pathname;
const isActive = (m: string) =>
  m === homePath ? path === homePath : path === m || path.startsWith(m);
---

<nav
  id="site-nav"
  class="fixed inset-x-0 top-0 z-[80] border-b border-transparent transition-[border-color,background] duration-300 bg-[color-mix(in_srgb,var(--color-ink-50)_88%,transparent)] backdrop-blur-[14px] backdrop-saturate-[1.6]"
>
  <div class="mx-auto flex h-nav max-w-shell items-center justify-between px-gutter">
    <a class="flex items-center gap-2.5 font-serif text-[20px] tracking-[-0.01em]" href={withBase('/')}>
      <Icon name="logo" size={22} />
      <span>Moovit</span>
    </a>

    <div class="hidden items-center gap-8 lg:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            aria-current={isActive(l.match) ? 'page' : undefined}
            class:list={[
              'relative py-1.5 font-mono text-[11.5px] uppercase tracking-[0.16em] transition-colors duration-200',
              isActive(l.match)
                ? 'text-ink-900 after:absolute after:-bottom-0.5 after:left-0 after:h-px after:w-3 after:bg-accent after:content-[""]'
                : 'text-ink-700 hover:text-ink-900',
            ]}
          >
            {l.label}
          </a>
        ))
      }
      <a
        href={withBase('/contact/')}
        class="group inline-flex items-center gap-2 rounded-full border border-ink-800 bg-ink-800 px-[18px] py-2.5 font-mono text-[11.5px] uppercase tracking-[0.16em] text-ink-50 transition-all duration-[250ms] hover:border-accent hover:bg-accent"
      >
        Contact <Icon name="arrow" size={12} />
      </a>
    </div>

    <button
      id="nav-toggle"
      type="button"
      class="flex h-10 w-10 flex-col items-center justify-center gap-[5px] rounded-full border border-ink-300 bg-transparent transition-[background,border-color] duration-200 hover:border-ink-700 lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="bar block h-[1.5px] w-4 bg-ink-800 transition-transform duration-300"></span>
      <span class="bar block h-[1.5px] w-4 bg-ink-800 transition-transform duration-300"></span>
    </button>
  </div>
</nav>

<div
  id="mobile-menu"
  class="fixed inset-x-0 bottom-0 top-nav z-[70] -translate-y-2 overflow-y-auto bg-ink-50 opacity-0 pointer-events-none transition-[transform,opacity] duration-300"
  aria-hidden="true"
>
  <div class="flex flex-col gap-1 px-gutter pb-12 pt-8">
    {
      links.map((l) => (
        <a
          href={l.href}
          aria-current={isActive(l.match) ? 'page' : undefined}
          class:list={[
            'flex items-baseline justify-between border-b border-ink-200 py-4 font-serif text-[32px] tracking-[-0.015em] transition-colors duration-200 hover:text-accent',
            isActive(l.match) ? 'text-accent' : 'text-ink-900',
          ]}
        >
          {l.label}
        </a>
      ))
    }
    <a
      href={withBase('/contact/')}
      class="mt-8 inline-flex items-center justify-center gap-2.5 rounded-full bg-ink-900 px-7 py-[18px] font-mono text-[12px] uppercase tracking-[0.16em] text-ink-50 transition-colors duration-200 hover:bg-accent"
    >
      Contact <Icon name="arrow" size={14} />
    </a>
  </div>
</div>

<script>
  // モバイルメニュー開閉 + scroll 時の border 表示。最小限の inline DOM スクリプト。
  const nav = document.getElementById('site-nav');
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const bars = toggle?.querySelectorAll<HTMLElement>('.bar');

  const setOpen = (open: boolean) => {
    if (!toggle || !menu) return;
    toggle.setAttribute('aria-expanded', String(open));
    toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    menu.setAttribute('aria-hidden', String(!open));
    menu.classList.toggle('translate-y-0', open);
    menu.classList.toggle('-translate-y-2', !open);
    menu.classList.toggle('opacity-100', open);
    menu.classList.toggle('opacity-0', !open);
    menu.classList.toggle('pointer-events-auto', open);
    menu.classList.toggle('pointer-events-none', !open);
    if (bars && bars.length === 2) {
      bars[0].classList.toggle('translate-y-[3.25px]', open);
      bars[0].classList.toggle('rotate-45', open);
      bars[1].classList.toggle('-translate-y-[3.25px]', open);
      bars[1].classList.toggle('-rotate-45', open);
    }
    document.body.style.overflow = open ? 'hidden' : '';
  };

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!isOpen);
  });

  // ESC で閉じる
  window.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && toggle?.getAttribute('aria-expanded') === 'true') {
      setOpen(false);
    }
  });

  // スクロール量で nav の border を出す
  const onScroll = () => {
    if (!nav) return;
    if (window.scrollY > 20) {
      nav.classList.remove('border-transparent');
      nav.classList.add('border-ink-200');
    } else {
      nav.classList.remove('border-ink-200');
      nav.classList.add('border-transparent');
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
